ANTHROPIC_API_KEY=sk-ant-...
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret
PORT=3000
# Optional: claude-sonnet-4-6 (default), claude-opus-4-6, claude-haiku-4-5
AI_MODEL=claude-sonnet-4-6
# Pro features
ENABLE_SECURITY_SCAN=true         # Security vulnerability scanning
ENABLE_QUALITY_SCORE=true        # Code quality scoring (0-100)
# Free tier limit (default: 10 PRs/month)
FREE_TIER_LIMIT=10
